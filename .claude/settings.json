{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "./vendor/bin/pint --dirty"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [],
        "deny": [
            "Read(./.env)"
        ],
        "ask": []
    },
    "enabledMcpjsonServers": [
        "laravel-boost"
    ],
    "enableAllProjectMcpServers": true
}
